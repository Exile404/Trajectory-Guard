# Model provider switch: ollama (phases 1-5) | bedrock (phase 6)
PROVIDER=ollama

# Ollama (local)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:14b

# Bedrock (phase 6 only)
PROVIDER=bedrock
AWS_REGION=ap-southeast-2
BEDROCK_MODEL_ID=au.anthropic.claude-opus-4-6-v1
AWS_BEARER_TOKEN_BEDROCK="PASTE YOUR AWS BEARER TOKEN HERE"
# AWS creds via standard chain (aws configure / env / IAM role). Never commit keys.

# Agent config
MAX_STEPS=6
