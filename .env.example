# Model provider switch: ollama (phases 1-5) | bedrock (phase 6)
PROVIDER=ollama

# Ollama (local)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Bedrock (phase 6 only)
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.amazon.nova-lite-v1:0
# AWS creds via standard chain (aws configure / env / IAM role). Never commit keys.

# Agent config
MAX_STEPS=6
